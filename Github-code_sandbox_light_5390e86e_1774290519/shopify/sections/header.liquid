{% comment %}
================================================================================
  sections/header.liquid
  株式会社 MEDI ALPHA PLUS — Shopify ヘッダーセクション
  PC版・モバイル版（ドロワーナビ）を完全再現した1ファイル完結版
  依存CDN:
    ・Google Fonts (Noto Sans JP + Inter) — layout/theme.liquid で読み込む
    ・Font Awesome 6.4.0               — layout/theme.liquid で読み込む
================================================================================
{% endcomment %}

{%- comment -%} ── CSS変数・スコープ ── {%- endcomment -%}
<style>
/* ══════════════════════════════════════════════════════
   0. CSS 変数（テーマカラー）
══════════════════════════════════════════════════════ */
:root {
  --map-navy:       #0d2b5e;
  --map-navy-dark:  #081a3d;
  --map-navy-mid:   #1a3a7a;
  --map-blue:       #1e6abf;
  --map-blue-light: #4a90d9;
  --map-cyan:       #00a8d4;
  --map-white:      #ffffff;
  --map-off-white:  #f4f7fb;
  --map-gray-light: #e8edf5;
  --map-gray:       #b0bccf;
  --map-text-dark:  #0d1b2e;
  --map-text-mid:   #3a4a5c;
  --map-text-light: #6b7a8d;
}

/* ══════════════════════════════════════════════════════
   1. TOP BAR（最上部：ネイビー帯 34px）
══════════════════════════════════════════════════════ */
.map-top-bar {
  background: var(--map-navy);
  height: 34px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 52px;
  position: fixed;
  top: 0;
  width: 100%;
  z-index: 1001;
  box-sizing: border-box;
}

/* キャッチコピー（左） */
.map-top-catch {
  font-size: 11px;
  color: rgba(255,255,255,0.65);
  letter-spacing: 0.12em;
  display: flex;
  align-items: center;
  gap: 10px;
  font-family: 'Noto Sans JP', sans-serif;
}
.map-top-catch::before {
  content: '';
  display: block;
  width: 18px;
  height: 1px;
  background: var(--map-cyan);
  opacity: 0.8;
}

/* 右エリア */
.map-top-right {
  display: flex;
  align-items: center;
  gap: 14px;
}

/* バッジ（24hメール受付） */
.map-top-badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: rgba(0,168,212,0.18);
  border: 1px solid rgba(0,168,212,0.4);
  color: var(--map-cyan);
  font-size: 10px;
  font-weight: 700;
  padding: 3px 12px;
  border-radius: 20px;
  letter-spacing: 0.06em;
  font-family: 'Noto Sans JP', sans-serif;
}
.map-top-badge i { font-size: 8px; }

/* ══════════════════════════════════════════════════════
   2. NAVBAR（白背景・高さ76px、top:34px）
══════════════════════════════════════════════════════ */
.map-nav {
  position: fixed;
  top: 34px;
  width: 100%;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40px;
  height: 76px;
  background: #ffffff;
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid rgba(13,43,94,0.10);
  transition: box-shadow 0.3s;
  gap: 12px;
  box-shadow: 0 2px 16px rgba(13,43,94,0.07);
  box-sizing: border-box;
}
.map-nav.scrolled {
  box-shadow: 0 4px 24px rgba(13,43,94,0.13);
}

/* ── ロゴ ── */
.map-nav-logo {
  display: flex;
  align-items: center;
  gap: 10px;
  text-decoration: none;
  flex-shrink: 0;
}
.map-logo-icon {
  width: 40px;
  height: 40px;
  background: linear-gradient(135deg, var(--map-navy) 0%, var(--map-blue) 100%);
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  font-weight: 900;
  color: #fff;
  font-family: 'Inter', sans-serif;
  flex-shrink: 0;
  box-shadow: 0 3px 12px rgba(13,43,94,0.25);
}
.map-logo-text-wrap {
  display: flex;
  flex-direction: column;
  gap: 1px;
}
.map-logo-sub {
  font-size: 8px;
  color: var(--map-blue);
  letter-spacing: 0.2em;
  text-transform: uppercase;
  font-weight: 600;
  font-family: 'Inter', sans-serif;
  line-height: 1;
}
.map-logo-name {
  font-size: 15px;
  font-weight: 800;
  color: var(--map-navy);
  letter-spacing: 0.05em;
  line-height: 1.1;
  font-family: 'Inter', sans-serif;
}

/* ── ナビリンク（PCのみ表示） ── */
.map-nav-links {
  display: flex;
  align-items: center;
  gap: 0;
  list-style: none;
  flex: 1;
  justify-content: center;
  margin: 0;
  padding: 0;
}
.map-nav-links a {
  display: block;
  padding: 6px 11px;
  color: var(--map-text-mid);
  text-decoration: none;
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 0.02em;
  border-radius: 6px;
  transition: all 0.2s;
  white-space: nowrap;
  position: relative;
  font-family: 'Noto Sans JP', sans-serif;
}
.map-nav-links a::after {
  content: '';
  position: absolute;
  bottom: 2px;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 2px;
  background: var(--map-blue);
  border-radius: 2px;
  transition: width 0.25s;
}
.map-nav-links a:hover { color: var(--map-navy); }
.map-nav-links a:hover::after { width: 65%; }

/* ── 右エリア（電話カード＋CTAボタン） ── */
.map-nav-contact {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-shrink: 0;
}

/* ── 電話カード ── */
.map-phone-btn {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  text-decoration: none;
  background: linear-gradient(135deg, #f0f5ff 0%, #ffffff 100%);
  border: 1.5px solid rgba(13,43,94,0.14);
  border-radius: 12px;
  padding: 6px 16px 6px 8px;
  transition: all 0.25s;
  white-space: nowrap;
  box-shadow: 0 2px 12px rgba(13,43,94,0.08);
  position: relative;
  overflow: hidden;
}
/* 左端アクセントライン */
.map-phone-btn::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 3px;
  background: linear-gradient(to bottom, var(--map-cyan), var(--map-blue));
  border-radius: 12px 0 0 12px;
}
.map-phone-btn:hover {
  border-color: var(--map-blue);
  background: linear-gradient(135deg, #e8f0ff 0%, #f8fbff 100%);
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(13,43,94,0.14);
}

/* 電話アイコン */
.map-phone-icon {
  width: 32px;
  height: 32px;
  background: linear-gradient(135deg, var(--map-navy), var(--map-blue));
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 3px 10px rgba(13,43,94,0.22);
}
.map-phone-icon i { font-size: 13px; color: #fff; }

/* 電話テキスト */
.map-phone-text {
  display: flex;
  flex-direction: column;
  gap: 1px;
}
.map-phone-label {
  font-size: 9px;
  letter-spacing: 0.14em;
  color: var(--map-cyan);
  font-weight: 800;
  line-height: 1;
  font-family: 'Noto Sans JP', sans-serif;
}
.map-phone-number {
  font-family: 'Inter', sans-serif;
  font-size: 16px;
  font-weight: 900;
  color: var(--map-navy);
  letter-spacing: 0.06em;
  line-height: 1.1;
}
.map-phone-hours {
  font-size: 8.5px;
  color: var(--map-text-light);
  letter-spacing: 0.02em;
  line-height: 1.25;
  font-family: 'Noto Sans JP', sans-serif;
  margin-top: 1px;
}

/* ── 見積依頼 CTAボタン ── */
.map-estimate-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  text-decoration: none;
  background: linear-gradient(135deg, var(--map-navy) 0%, var(--map-blue) 100%);
  color: #fff;
  font-size: 13px;
  font-weight: 800;
  letter-spacing: 0.04em;
  padding: 10px 22px;
  border-radius: 10px;
  white-space: nowrap;
  flex-shrink: 0;
  box-shadow: 0 4px 16px rgba(13,43,94,0.32);
  transition: all 0.25s;
  position: relative;
  overflow: hidden;
  font-family: 'Noto Sans JP', sans-serif;
}
/* シマーエフェクト */
.map-estimate-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 60%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.18), transparent);
  transition: left 0.5s;
}
.map-estimate-btn:hover::before { left: 150%; }
.map-estimate-btn:hover {
  background: linear-gradient(135deg, var(--map-blue) 0%, var(--map-navy-mid) 100%);
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(13,43,94,0.38);
}
/* 矢印サークル */
.map-btn-arrow {
  width: 20px;
  height: 20px;
  background: rgba(255,255,255,0.18);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 10px;
  transition: transform 0.25s;
}
.map-estimate-btn:hover .map-btn-arrow { transform: translateX(3px); }

/* ── ハンバーガーボタン（モバイルのみ） ── */
.map-hamburger {
  display: none;
  flex-direction: column;
  justify-content: center;
  gap: 5px;
  background: var(--map-off-white);
  border: 1px solid var(--map-gray-light);
  border-radius: 8px;
  cursor: pointer;
  padding: 8px 10px;
  z-index: 1100;
}
.map-hamburger span {
  display: block;
  width: 22px;
  height: 2px;
  background: var(--map-navy);
  border-radius: 2px;
  transition: all 0.3s;
}
/* アクティブ時（✕ 形） */
.map-hamburger.active span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.map-hamburger.active span:nth-child(2) { opacity: 0; }
.map-hamburger.active span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

/* ══════════════════════════════════════════════════════
   3. モバイルドロワー
══════════════════════════════════════════════════════ */

/* ── オーバーレイ（ドロワー背後の暗幕） ── */
.map-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.35);
  z-index: 998;
  backdrop-filter: blur(2px);
}
.map-overlay.open { display: block; }

/* ── ドロワー本体 ── */
.map-drawer {
  display: none;            /* JSで flex に切り替え */
  position: fixed;
  top: 0;
  right: -100%;
  width: min(300px, 88vw);
  height: 100vh;
  height: 100dvh;           /* iOS 対応 */
  background: #fff;
  z-index: 999;
  flex-direction: column;
  gap: 0;
  border-left: 1px solid var(--map-gray-light);
  box-shadow: -8px 0 40px rgba(13,43,94,0.12);
  transition: right 0.35s cubic-bezier(0.4,0,0.2,1);
  overflow: hidden;
  -webkit-overflow-scrolling: touch;
}
.map-drawer.open { right: 0; }

/* ── ドロワーヘッダー（ロゴ＋閉じるボタン、固定） ── */
.map-drawer-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  border-bottom: 2px solid var(--map-gray-light);
  background: var(--map-white);
  flex-shrink: 0;
  z-index: 10;
}
/* ドロワー内ロゴ */
.map-drawer-logo {
  display: flex;
  align-items: center;
  gap: 10px;
  text-decoration: none;
}
.map-drawer-logo-icon {
  width: 34px;
  height: 34px;
  background: linear-gradient(135deg, var(--map-navy), var(--map-blue));
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 14px;
  font-weight: 900;
  flex-shrink: 0;
  font-family: 'Inter', sans-serif;
}
.map-drawer-logo-text {
  display: flex;
  flex-direction: column;
}
.map-drawer-logo-sub  {
  font-size: 7px;
  color: var(--map-text-light);
  letter-spacing: 0.08em;
  line-height: 1;
  font-family: 'Inter', sans-serif;
}
.map-drawer-logo-name {
  font-size: 11px;
  font-weight: 900;
  color: var(--map-navy);
  letter-spacing: 0.04em;
  line-height: 1.3;
  font-family: 'Inter', sans-serif;
}
/* 閉じるボタン */
.map-drawer-close {
  width: 36px;
  height: 36px;
  background: var(--map-off-white);
  border: 1px solid var(--map-gray-light);
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  font-size: 16px;
  color: var(--map-navy);
  flex-shrink: 0;
  transition: background 0.2s;
}
.map-drawer-close:hover { background: var(--map-gray-light); }

/* ── ホームリンク（ヘッダー直下・スクロール外・常に表示） ── */
.map-drawer-home {
  flex-shrink: 0;
  background: var(--map-off-white);
  border-bottom: 2px solid var(--map-gray-light);
  display: flex;
  align-items: center;
  padding: 11px 20px;
  color: var(--map-text-mid);
  text-decoration: none;
  font-size: 13px;
  font-weight: 500;
  gap: 8px;
  font-family: 'Noto Sans JP', sans-serif;
  transition: background 0.2s;
}
.map-drawer-home:hover { background: #e8f0fc; }

/* ── スクロール可能エリア ── */
.map-drawer-scroll {
  flex: 1;
  overflow-y: auto;
  overflow-x: hidden;
  -webkit-overflow-scrolling: touch;
  padding-bottom: 24px;
}

/* ── ドロワーナビリンク ── */
.map-drawer-link {
  display: flex;
  align-items: center;
  padding: 11px 20px;
  color: var(--map-text-mid);
  text-decoration: none;
  font-size: 13px;
  font-weight: 500;
  border-bottom: 1px solid var(--map-gray-light);
  transition: all 0.2s;
  gap: 8px;
  font-family: 'Noto Sans JP', sans-serif;
  position: relative;
}
.map-drawer-link::before {
  content: '';
  display: block;
  width: 3px;
  height: 16px;
  background: transparent;
  border-radius: 2px;
  transition: background 0.2s;
  flex-shrink: 0;
}
.map-drawer-link:hover {
  background: var(--map-off-white);
  color: var(--map-navy);
  padding-left: 28px;
}
.map-drawer-link:hover::before { background: var(--map-blue); }

/* ── ドロワー内 見積依頼CTAボタン ── */
.map-drawer-estimate {
  margin: 14px 16px 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  background: linear-gradient(135deg, var(--map-navy), var(--map-blue));
  color: #fff;
  text-decoration: none;
  padding: 12px 16px;
  border-radius: 10px;
  font-size: 13px;
  font-weight: 800;
  letter-spacing: 0.04em;
  box-shadow: 0 4px 16px rgba(13,43,94,0.28);
  transition: all 0.25s;
  font-family: 'Noto Sans JP', sans-serif;
}
.map-drawer-estimate:hover {
  background: linear-gradient(135deg, var(--map-blue), var(--map-navy-mid));
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(13,43,94,0.36);
}
.map-drawer-estimate i { font-size: 14px; }

/* ── ドロワー内 コンタクト情報カード ── */
.map-drawer-contact {
  margin: 12px 16px 0;
  padding: 14px 16px;
  background: var(--map-off-white);
  border-radius: 12px;
  border: 1px solid var(--map-gray-light);
}
.map-drawer-contact-label {
  font-size: 9px;
  font-weight: 800;
  letter-spacing: 0.16em;
  color: var(--map-cyan);
  text-transform: uppercase;
  margin-bottom: 4px;
  font-family: 'Noto Sans JP', sans-serif;
}
.map-drawer-phone {
  display: flex;
  align-items: center;
  gap: 7px;
  text-decoration: none;
  color: var(--map-navy);
  font-family: 'Inter', sans-serif;
  font-size: 18px;
  font-weight: 900;
  letter-spacing: 0.04em;
  margin-bottom: 3px;
}
.map-drawer-phone i { color: var(--map-blue); font-size: 13px; }
.map-drawer-hours {
  font-size: 9.5px;
  color: var(--map-text-light);
  line-height: 1.5;
  margin-bottom: 10px;
  font-family: 'Noto Sans JP', sans-serif;
}
.map-drawer-email {
  display: flex;
  align-items: center;
  gap: 6px;
  text-decoration: none;
  color: var(--map-text-light);
  font-size: 11px;
  padding: 4px 0;
  font-family: 'Noto Sans JP', sans-serif;
}
.map-drawer-email i { color: var(--map-blue); font-size: 10px; }

/* ══════════════════════════════════════════════════════
   4. ページオフセット（top-bar 34px + nav 76px = 110px）
══════════════════════════════════════════════════════ */
.map-page-offset { height: 110px; }

/* ══════════════════════════════════════════════════════
   5. レスポンシブ
══════════════════════════════════════════════════════ */

/* ── PC（1024px以上）── */
@media (min-width: 1024px) {
  .map-nav-links   { display: flex !important; }
  .map-nav-contact { display: flex !important; }
  .map-hamburger   { display: none !important; }
  .map-drawer      { display: none !important; }
}

/* ── タブレット・スマホ（1023px以下）── */
@media (max-width: 1023px) {
  .map-nav         { padding: 0 24px; }
  .map-nav-links   { display: none !important; }
  .map-nav-contact { display: none !important; }
  .map-hamburger   { display: flex !important; }
  .map-drawer      { display: flex; }
}

/* ── スマホ（767px以下）── */
@media (max-width: 767px) {
  .map-top-bar    { padding: 0 20px; }
  .map-top-catch  { display: none; }
  .map-nav        { padding: 0 20px; }
}

/* ── Medium PC（1024〜1380px）── */
@media (min-width: 1024px) and (max-width: 1380px) {
  .map-nav          { padding: 0 16px; gap: 8px; }
  .map-nav-links    { gap: 0; }
  .map-nav-links a  { padding: 6px 8px; font-size: 12px; }
  .map-nav-contact  { gap: 8px; }
  .map-phone-btn    { padding: 6px 12px 6px 8px; gap: 8px; }
  .map-phone-icon   { width: 30px; height: 30px; border-radius: 7px; }
  .map-phone-icon i { font-size: 12px; }
  .map-phone-number { font-size: 15px; }
  .map-phone-hours  { font-size: 8px; }
  .map-estimate-btn { font-size: 12px; padding: 9px 16px; }
  .map-logo-name    { font-size: 14px; }
}

/* ── 大型PC（1381px以上）── */
@media (min-width: 1381px) {
  .map-nav     { padding: 0 48px; }
  .map-top-bar { padding: 0 48px; }
}
</style>

{%- comment -%}
================================================================================
  HTML — TOP BAR
================================================================================
{%- endcomment -%}
<div class="map-top-bar" id="mapTopBar">
  <div class="map-top-catch">{{ section.settings.top_catch }}</div>
  <div class="map-top-right">
    <div class="map-top-badge">
      <i class="fa fa-envelope"></i>{{ section.settings.top_badge_label }}
    </div>
  </div>
</div>

{%- comment -%}
================================================================================
  HTML — NAVBAR
================================================================================
{%- endcomment -%}
<nav class="map-nav" id="mapNavbar">

  {%- comment -%} ロゴ {%- endcomment -%}
  <a href="{{ routes.root_url }}" class="map-nav-logo">
    <div class="map-logo-icon">M</div>
    <div class="map-logo-text-wrap">
      <div class="map-logo-sub">{{ section.settings.logo_sub }}</div>
      <div class="map-logo-name">{{ section.settings.logo_name }}</div>
    </div>
  </a>

  {%- comment -%} ナビリンク（PCのみ） {%- endcomment -%}
  <ul class="map-nav-links" id="mapNavLinks">
    <li><a href="{{ routes.root_url }}">{{ section.settings.nav_home }}</a></li>
    <li><a href="#proposal">{{ section.settings.nav_proposal }}</a></li>
    <li><a href="#services">{{ section.settings.nav_services }}</a></li>
    <li><a href="#shop">{{ section.settings.nav_shop }}</a></li>
    <li><a href="#achievements">{{ section.settings.nav_achievements }}</a></li>
    <li><a href="#pricing">{{ section.settings.nav_pricing }}</a></li>
    <li><a href="#vehicles">{{ section.settings.nav_vehicles }}</a></li>
    <li><a href="#about">{{ section.settings.nav_about }}</a></li>
  </ul>

  {%- comment -%} 右エリア：電話カード＋CTA {%- endcomment -%}
  <div class="map-nav-contact">

    {%- comment -%} 電話カード {%- endcomment -%}
    <a href="tel:{{ section.settings.phone_raw }}" class="map-phone-btn">
