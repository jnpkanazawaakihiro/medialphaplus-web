{%- comment -%}
================================================================================
  JavaScript — スクロール検知 / ハンバーガー / ドロワー開閉
================================================================================
{%- endcomment -%}
<script>
(function() {
  /* ── Navbar スクロール検知（scrolled クラス） ── */
  var navbar = document.getElementById('mapNavbar');
  if (navbar) {
    window.addEventListener('scroll', function() {
      navbar.classList.toggle('scrolled', window.scrollY > 60);
    });
  }

  /* ── ハンバーガー・ドロワー制御 ── */
  var hamburger = document.getElementById('mapHamburger');
  var drawer    = document.getElementById('mapDrawer');
  var overlay   = document.getElementById('mapOverlay');

  function mapOpenDrawer() {
    if (!hamburger || !drawer || !overlay) return;
    hamburger.classList.add('active');
    drawer.classList.add('open');
    overlay.classList.add('open');
    document.body.style.overflow = 'hidden'; /* 背後スクロール禁止 */
  }

  /* グローバルに公開（inline onclick から呼べるように） */
  window.mapCloseDrawer = function() {
    if (!hamburger || !drawer || !overlay) return;
    hamburger.classList.remove('active');
    drawer.classList.remove('open');
    overlay.classList.remove('open');
    document.body.style.overflow = '';
  };

  if (hamburger) hamburger.addEventListener('click', mapOpenDrawer);
  if (overlay)   overlay.addEventListener('click', window.mapCloseDrawer);

  /* ESC キーで閉じる */
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') window.mapCloseDrawer();
  });
})();
</script>

