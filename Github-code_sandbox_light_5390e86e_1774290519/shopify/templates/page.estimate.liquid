{% comment %}
  =========================================================
  MEDI ALPHA PLUS — 見積依頼フォーム
  テンプレート: page.estimate.liquid
  使い方:
    1. Shopify管理画面 > オンラインストア > テーマ > コードを編集
    2. templates/ フォルダに page.estimate.liquid を作成して貼り付け
    3. ページ管理 > 新しいページ > テンプレートで「page.estimate」を選択
    4. 送信データは 管理画面 > お問い合わせ に届く
  =========================================================
{% endcomment %}

{{ 'estimate-form.css' | asset_url | stylesheet_tag }}
<link href="https://fonts.googleapis.com/css2?family=Zen+Old+Mincho:wght@400;500;700;900&family=Noto+Sans+JP:wght@300;400;500;700;900&family=Inter:wght@300;400;600;700;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.4.0/css/all.min.css">

{%- if form.posted_successfully? -%}
  <div class="ef-thanks-overlay show" id="thanksOverlay">
    <div class="ef-thanks-modal">
      <div class="ef-thanks-icon"><i class="fa fa-check"></i></div>
      <h2 class="ef-thanks-title">送信が完了しました</h2>
      <p class="ef-thanks-msg">
        お見積りのご依頼、誠にありがとうございます。<br>
        内容を確認の上、<strong>翌営業日以内</strong>に担当者よりご連絡いたします。
      </p>
      <div class="ef-thanks-info">
        <div class="ef-thanks-info-item">
          <i class="fa fa-phone"></i>
          <div>
            <div class="ef-thanks-info-label">お急ぎの方はお電話ください</div>
            <div class="ef-thanks-info-value">0120-843-297</div>
          </div>
        </div>
        <div class="ef-thanks-info-item">
          <i class="fa fa-envelope"></i>
          <div>
            <div class="ef-thanks-info-label">メールでのお問い合わせ</div>
            <div class="ef-thanks-info-value">info@medialphaplus.com</div>
          </div>
        </div>
      </div>
      <a href="{{ shop.url }}" class="ef-thanks-btn">
        <i class="fa fa-home"></i> トップページへ戻る
      </a>
    </div>
  </div>
{%- endif -%}

<!-- ヒーローセクション -->
<div class="ef-hero">
  <div class="ef-hero-inner">
    <div class="ef-hero-eyebrow">Estimate Request</div>
    <h1 class="ef-hero-title">無料<span>見積依頼</span>フォーム</h1>
    <p class="ef-hero-lead">
      医療輸送・衛生消耗品・輸送支援コンサルティングについて、<br>
      まずはお気軽にお問い合わせください。<br>
      専任スタッフが<strong>翌営業日以内</strong>にご連絡いたします。
    </p>
    <div class="ef-steps">
      <div class="ef-step ef-step--active">
        <div class="ef-step-num">1</div>
        フォーム入力
      </div>
      <div class="ef-step-arrow"></div>
      <div class="ef-step">
        <div class="ef-step-num">2</div>
        内容確認
      </div>
      <div class="ef-step-arrow"></div>
      <div class="ef-step">
        <div class="ef-step-num">3</div>
        送信完了
      </div>
      <div class="ef-step-arrow"></div>
      <div class="ef-step">
        <div class="ef-step-num">4</div>
        担当者よりご連絡
      </div>
    </div>
  </div>
</div>

<!-- メインコンテンツ -->
<div class="ef-main">
  <div class="ef-layout">

    <!-- ══════════════════════════════
         フォーム本体
    ══════════════════════════════ -->
    <div class="ef-form-wrap">

      {%- form 'contact', id: 'estimateForm', class: 'ef-form' -%}

        {%- if form.errors -%}
          <div class="ef-error-box">
            <i class="fa fa-exclamation-circle"></i>
            入力内容にエラーがあります。ご確認のうえ再送信してください。
            <ul>
              {%- for field in form.errors -%}
                <li>{{ field }}: {{ form.errors.messages[field] }}</li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}

        <!-- ── CARD 1: 基本情報 ── -->
        <div class="ef-card">
          <div class="ef-card-header">
            <div class="ef-card-icon"><i class="fa fa-building"></i></div>
            <div>
              <h2>基本情報</h2>
              <p>ご担当者様の情報をご入力ください</p>
            </div>
          </div>
          <div class="ef-card-body">

            <div class="ef-section-label">会社・医療機関情報</div>
            <div class="ef-row">
              <div class="ef-group">
                <label for="contact[company]">
                  会社名・医療機関名 <span class="ef-required">必須</span>
                </label>
                <input type="text"
                       id="contact[company]"
                       name="contact[body]"
                       class="ef-input"
                       placeholder="例：〇〇クリニック / 株式会社〇〇"
                       data-key="会社名・医療機関名"
                       required>
              </div>
              <div class="ef-group">
                <label for="ef-facility">
                  業種・施設種別 <span class="ef-required">必須</span>
                </label>
                <select id="ef-facility" name="contact[body]" class="ef-input ef-select" data-key="業種・施設種別" required>
                  <option value="">選択してください</option>
                  <optgroup label="医療機関">
                    <option>クリニック・診療所</option>
                    <option>病院</option>
                    <option>検査センター・臨床検査会社</option>
                    <option>健診センター</option>
                  </optgroup>
                  <optgroup label="研究・製薬">
                    <option>製薬会社</option>
                    <option>SMO（治験施設支援機関）</option>
                    <option>CRO（医薬品開発業務受託機関）</option>
                    <option>大学・研究機関</option>
                  </optgroup>
                  <optgroup label="その他">
                    <option>物流・輸送会社</option>
                    <option>その他</option>
                  </optgroup>
                </select>
              </div>
            </div>

            <div class="ef-section-label" style="margin-top:28px;">担当者情報</div>
            <div class="ef-row">
              <div class="ef-group">
                <label for="contact[name]">
                  担当者名 <span class="ef-required">必須</span>
                </label>
                <input type="text"
                       id="contact[name]"
                       name="contact[name]"
                       class="ef-input"
                       placeholder="例：山田 太郎"
                       required>
              </div>
              <div class="ef-group">
                <label for="ef-name-kana">担当者名（フリガナ）<span class="ef-optional">任意</span></label>
                <input type="text" id="ef-name-kana" class="ef-input" data-key="担当者名フリガナ" placeholder="例：ヤマダ タロウ">
              </div>
            </div>
            <div class="ef-row">
              <div class="ef-group">
                <label for="contact[phone]">
                  電話番号 <span class="ef-required">必須</span>
                </label>
                <input type="tel"
                       id="contact[phone]"
                       class="ef-input"
                       data-key="電話番号"
                       placeholder="例：03-1234-5678"
                       required>
              </div>
              <div class="ef-group">
                <label for="contact[email]">
                  メールアドレス <span class="ef-required">必須</span>
                </label>
                <input type="email"
                       id="contact[email]"
                       name="contact[email]"
                       class="ef-input"
                       placeholder="例：info@example.com"
                       required>
              </div>
            </div>

          </div>
        </div>

        <!-- ── CARD 2: ご希望のサービス ── -->
        <div class="ef-card">
          <div class="ef-card-header">
            <div class="ef-card-icon"><i class="fa fa-concierge-bell"></i></div>
            <div>
              <h2>ご希望のサービス</h2>
              <p>該当するサービスをすべてお選びください</p>
            </div>
          </div>
