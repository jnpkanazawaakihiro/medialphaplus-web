      <!-- 対応エリア -->
      <div class="ef-scard">
        <div class="ef-scard-header">
          <h3><i class="fa fa-map-marker-alt" style="color:var(--ef-gold);margin-right:8px;"></i> 主な対応エリア</h3>
        </div>
        <div class="ef-scard-body">
          <div class="ef-area-tags">
