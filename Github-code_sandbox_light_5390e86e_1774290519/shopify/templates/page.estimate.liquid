                <div class="ef-check-box"></div>
                <i class="fa fa-ellipsis-h ef-check-icon"></i>
                <span class="ef-check-label">その他・複合</span>
              </div>
            </div>

            <div class="ef-divider"></div>

            <div class="ef-section-label">輸送エリア・ルート</div>
            <div class="ef-row">
              <div class="ef-group">
                <label>集荷エリア <span class="ef-optional">任意</span></label>
                <input type="text" class="ef-input" data-key="集荷エリア" placeholder="例：東京都内・埼玉県南部">
              </div>
              <div class="ef-group">
                <label>納品先エリア <span class="ef-optional">任意</span></label>
