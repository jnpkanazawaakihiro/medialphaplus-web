<script>
/* ══════════════════════════════════════
   MEDI ALPHA PLUS — Estimate Form JS
   ══════════════════════════════════════ */

// チェックボックス
function efToggleCheck(el) {
  el.classList.toggle('ef-checked');
  el.querySelector('input').checked = el.classList.contains('ef-checked');
}

// ラジオボタン
function efToggleRadio(el, groupId) {
  document.querySelectorAll('#' + groupId + ' .ef-radio-item').forEach(function(item) {
    item.classList.remove('ef-checked');
    item.querySelector('input').checked = false;
  });
  el.classList.add('ef-checked');
  el.querySelector('input').checked = true;
}

// プライバシー同意
function efTogglePrivacy() {
  var el = document.getElementById('efPrivacy');
  el.classList.toggle('ef-checked');
  var isChecked = el.classList.contains('ef-checked');
  document.getElementById('ef_privacy_check').checked = isChecked;
  document.getElementById('efSubmitBtn').disabled = !isChecked;
}

// フォーム送信前：全入力を contact[body] に集約
document.addEventListener('DOMContentLoaded', function() {
  var form = document.getElementById('estimateForm');
  if (!form) return;

  form.addEventListener('submit', function(e) {

    // バリデーション
    var company = form.querySelector('[data-key="会社名・医療機関名"]');
    var name    = form.querySelector('[name="contact[name]"]');
    var phone   = form.querySelector('[data-key="電話番号"]');
    var email   = form.querySelector('[name="contact[email]"]');
    var services = form.querySelectorAll('#serviceGroup input[type="checkbox"]:checked');

    if (!company || !company.value.trim()) {
      e.preventDefault(); alert('会社名・医療機関名をご入力ください。'); return;
    }
    if (!name || !name.value.trim()) {
      e.preventDefault(); alert('担当者名をご入力ください。'); return;
    }
    if (!phone || !phone.value.trim()) {
      e.preventDefault(); alert('電話番号をご入力ください。'); return;
    }
    if (!email || !email.value.trim()) {
      e.preventDefault(); alert('メールアドレスをご入力ください。'); return;
    }
    if (services.length === 0) {
      e.preventDefault(); alert('ご希望のサービスを1つ以上お選びください。'); return;
    }

    // 全入力情報を1つの body テキストに集約
    var lines = [];

    // 会社名
    lines.push('【会社名・医療機関名】' + company.value.trim());

    // 業種
    var facility = form.querySelector('[data-key="業種・施設種別"]');
    if (facility && facility.value) lines.push('【業種・施設種別】' + facility.value);

    // 担当者名
    lines.push('【担当者名】' + name.value.trim());

    // フリガナ
    var kana = form.querySelector('[data-key="担当者名フリガナ"]');
    if (kana && kana.value.trim()) lines.push('【担当者名（フリガナ）】' + kana.value.trim());

    // 電話番号
    lines.push('【電話番号】' + phone.value.trim());

    // メール
    lines.push('【メールアドレス】' + email.value.trim());

    // サービス
    var svcVals = [];
    services.forEach(function(cb){ svcVals.push(cb.value); });
    lines.push('【ご希望のサービス】' + svcVals.join('、'));

    // 集荷エリア
    var pickup = form.querySelector('[data-key="集荷エリア"]');
    if (pickup && pickup.value.trim()) lines.push('【集荷エリア】' + pickup.value.trim());

    // 納品先エリア
    var delivery = form.querySelector('[data-key="納品先エリア"]');
    if (delivery && delivery.value.trim()) lines.push('【納品先エリア】' + delivery.value.trim());

    // 依頼頻度
    var freq = form.querySelector('#frequencyGroup .ef-checked input');
    if (freq) lines.push('【依頼頻度】' + freq.value);

    // 開始希望時期
    var timing = form.querySelector('#timingGroup .ef-checked input');
    if (timing) lines.push('【開始希望時期】' + timing.value);

    // 希望連絡方法
    var contact = form.querySelector('#contactGroup .ef-checked input');
    if (contact) lines.push('【希望連絡方法】' + contact.value);

    // フリーテキスト
    var bodyField = document.getElementById('efBodyField');
    if (bodyField && bodyField.value.trim()) {
      lines.push('');
      lines.push('【お問い合わせ内容・ご要望】');
      lines.push(bodyField.value.trim());
    }

    // hidden フィールドにセット
    document.getElementById('efHiddenBody').value = lines.join('\n');
  });
});
</script>
