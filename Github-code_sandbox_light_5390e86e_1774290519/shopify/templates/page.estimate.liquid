                </div>
                <div class="ef-radio-item" onclick="efToggleRadio(this,'frequencyGroup')">
                  <input type="radio" name="ef_frequency" value="週2〜3回" style="display:none;">
                  <div class="ef-radio-dot"></div>
                  <span class="ef-radio-label">週2〜3回</span>
                </div>
                <div class="ef-radio-item" onclick="efToggleRadio(this,'frequencyGroup')">
                  <input type="radio" name="ef_frequency" value="週1回" style="display:none;">
                  <div class="ef-radio-dot"></div>
                  <span class="ef-radio-label">週1回</span>
                </div>
                <div class="ef-radio-item" onclick="efToggleRadio(this,'frequencyGroup')">
                  <input type="radio" name="ef_frequency" value="スポット・不定期" style="display:none;">
                  <div class="ef-radio-dot"></div>
                  <span class="ef-radio-label">スポット・不定期</span>
                </div>
                <div class="ef-radio-item" onclick="efToggleRadio(this,'frequencyGroup')">
                  <input type="radio" name="ef_frequency" value="未定" style="display:none;">
                  <div class="ef-radio-dot"></div>
                  <span class="ef-radio-label">未定</span>
                </div>
              </div>
            </div>

            <div class="ef-group" style="margin-top:20px;">
              <label>開始希望時期 <span class="ef-optional">任意</span></label>
              <div class="ef-radio-group" id="timingGroup">
                <div class="ef-radio-item" onclick="efToggleRadio(this,'timingGroup')">
                  <input type="radio" name="ef_timing" value="今すぐ（できるだけ早く）" style="display:none;">
                  <div class="ef-radio-dot"></div>
                  <span class="ef-radio-label">今すぐ（できるだけ早く）</span>
                </div>
                <div class="ef-radio-item" onclick="efToggleRadio(this,'timingGroup')">
                  <input type="radio" name="ef_timing" value="1ヶ月以内" style="display:none;">
                  <div class="ef-radio-dot"></div>
                  <span class="ef-radio-label">1ヶ月以内</span>
                </div>
                <div class="ef-radio-item" onclick="efToggleRadio(this,'timingGroup')">
                  <input type="radio" name="ef_timing" value="3ヶ月以内" style="display:none;">
                  <div class="ef-radio-dot"></div>
                  <span class="ef-radio-label">3ヶ月以内</span>
                </div>
                <div class="ef-radio-item" onclick="efToggleRadio(this,'timingGroup')">
                  <input type="radio" name="ef_timing" value="検討段階" style="display:none;">
                  <div class="ef-radio-dot"></div>
                  <span class="ef-radio-label">検討段階</span>
                </div>
              </div>
            </div>

          </div>
        </div>

        <!-- ── CARD 3: ご質問・詳細 ── -->
        <div class="ef-card">
          <div class="ef-card-header">
            <div class="ef-card-icon"><i class="fa fa-comment-alt"></i></div>
            <div>
              <h2>ご質問・詳細</h2>
              <p>現在の課題・ご要望などをお聞かせください</p>
            </div>
          </div>
          <div class="ef-card-body">

            <div class="ef-group">
              <label>希望連絡方法 <span class="ef-optional">任意</span></label>
              <div class="ef-radio-group" id="contactGroup">
                <div class="ef-radio-item" onclick="efToggleRadio(this,'contactGroup')">
                  <input type="radio" name="ef_contact" value="電話" style="display:none;">
                  <div class="ef-radio-dot"></div>
                  <span class="ef-radio-label"><i class="fa fa-phone" style="color:var(--ef-gold);margin-right:4px;font-size:11px;"></i> 電話</span>
                </div>
                <div class="ef-radio-item" onclick="efToggleRadio(this,'contactGroup')">
                  <input type="radio" name="ef_contact" value="メール" style="display:none;">
                  <div class="ef-radio-dot"></div>
                  <span class="ef-radio-label"><i class="fa fa-envelope" style="color:var(--ef-gold);margin-right:4px;font-size:11px;"></i> メール</span>
                </div>
                <div class="ef-radio-item" onclick="efToggleRadio(this,'contactGroup')">
                  <input type="radio" name="ef_contact" value="どちらでも可" style="display:none;">
                  <div class="ef-radio-dot"></div>
                  <span class="ef-radio-label">どちらでも可</span>
                </div>
              </div>
            </div>

            <div class="ef-group" style="margin-top:20px;">
              <label for="contact[body]">お問い合わせ内容・ご要望 <span class="ef-optional">任意</span></label>
              <textarea id="contact[body]"
                        name="contact[body]"
                        class="ef-input ef-textarea"
                        id="efBodyField"
                        placeholder="現在の課題・ご要望・ご質問など、自由にお書きください。&#10;例：現在○○社に依頼しているが、コストを下げたい。検体の種類は〇〇で、週○回の回収が必要です。"></textarea>
            </div>

            <div class="ef-note">
              <i class="fa fa-info-circle"></i>
              ご入力いただいた個人情報は、見積依頼への対応・ご連絡のみに使用いたします。第三者への提供は行いません。
            </div>

            <!-- プライバシーポリシー同意 -->
            <div class="ef-privacy" id="efPrivacy" onclick="efTogglePrivacy()">
              <input type="checkbox" id="ef_privacy_check" style="display:none;">
              <div class="ef-privacy-box"></div>
              <div class="ef-privacy-text">
                <strong>プライバシーポリシーに同意する</strong><br>
                個人情報の取り扱いについて同意のうえ、送信してください。
              </div>
            </div>

            <!-- 送信ボタン -->
            <div class="ef-submit-area">
              <button type="submit" class="ef-submit-btn" id="efSubmitBtn" disabled>
                <i class="fa fa-paper-plane"></i>
                見積依頼を送信する
              </button>
              <div class="ef-submit-note">
                <i class="fa fa-lock" style="color:var(--ef-gold);margin-right:4px;"></i>
                送信内容は暗号化されて安全に送信されます
              </div>
            </div>

          </div>
        </div>

        <!-- hiddenフィールド：集約されたbodyを格納 -->
        <input type="hidden" name="contact[body]" id="efHiddenBody">

      {%- endform -%}

    </div><!-- /ef-form-wrap -->

    <!-- ══════════════════════════════
         サイドバー
