              </div>
            </div>

            <div class="ef-group" style="margin-top:20px;">
              <label>依頼頻度 <span class="ef-optional">任意</span></label>
              <div class="ef-radio-group" id="frequencyGroup">
                <div class="ef-radio-item" onclick="efToggleRadio(this,'frequencyGroup')">
                  <input type="radio" name="ef_frequency" value="毎日（週5〜6日）" style="display:none;">
                  <div class="ef-radio-dot"></div>
