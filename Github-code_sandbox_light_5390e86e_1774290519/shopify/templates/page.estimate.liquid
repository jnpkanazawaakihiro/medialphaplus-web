      </div>

      <!-- 選ばれる理由 -->
      <div class="ef-scard">
        <div class="ef-scard-header">
          <h3><i class="fa fa-star" style="color:var(--ef-gold);margin-right:8px;"></i> 選ばれる理由</h3>
        </div>
        <div class="ef-scard-body">
          <div class="ef-feature-list">
            <div class="ef-feature">
              <i class="fa fa-check-circle ef-feature-icon"></i>
              <div class="ef-feature-text"><strong>翌営業日以内</strong>にご連絡</div>
            </div>
            <div class="ef-feature">
              <i class="fa fa-check-circle ef-feature-icon"></i>
              <div class="ef-feature-text"><strong>見積・相談</strong>は完全無料</div>
            </div>
            <div class="ef-feature">
              <i class="fa fa-check-circle ef-feature-icon"></i>
              <div class="ef-feature-text"><strong>検体回収と消耗品納品</strong>を一括対応</div>
            </div>
            <div class="ef-feature">
              <i class="fa fa-check-circle ef-feature-icon"></i>
              <div class="ef-feature-text"><strong>緊急対応</strong>も当日中に調整</div>
            </div>
            <div class="ef-feature">
              <i class="fa fa-check-circle ef-feature-icon"></i>
              <div class="ef-feature-text">全スタッフ<strong>OJT研修完備</strong></div>
            </div>
          </div>
        </div>
