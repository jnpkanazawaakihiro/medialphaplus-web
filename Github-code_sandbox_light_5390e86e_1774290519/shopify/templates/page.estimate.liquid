            <div class="ef-contact-icon"><i class="fa fa-envelope"></i></div>
            <div>
              <div class="ef-contact-label">メール（24時間受付）</div>
              <div class="ef-contact-value" style="font-size:12px;">info@medialphaplus.com</div>
