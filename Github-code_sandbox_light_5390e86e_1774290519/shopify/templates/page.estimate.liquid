                <div class="ef-check-box"></div>
                <i class="fa fa-flask ef-check-icon"></i>
                <span class="ef-check-label">医療検体輸送</span>
              </div>
              <div class="ef-check-item" onclick="efToggleCheck(this)">
                <input type="checkbox" name="contact[body]" value="衛生消耗品販売" data-key="サービス" style="display:none;">
                <div class="ef-check-box"></div>
                <i class="fa fa-box ef-check-icon"></i>
                <span class="ef-check-label">衛生消耗品販売</span>
              </div>
              <div class="ef-check-item" onclick="efToggleCheck(this)">
                <input type="checkbox" name="contact[body]" value="輸送支援コンサルティング" data-key="サービス" style="display:none;">
