{% comment %}
  ============================================================
  MEDI ALPHA PLUS — ヘッダーセクション
  ファイル名: sections/header.liquid
  説明: トップバー＋ナビゲーション＋モバイルドロワーを1ファイルに統合
  ============================================================
{% endcomment %}

{% comment %} Font Awesome の読み込み（theme.liquidに未記載の場合はここで読み込む） {% endcomment %}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.4.0/css/all.min.css">

{% comment %} Google Fonts の読み込み（theme.liquidに未記載の場合はここで読み込む） {% endcomment %}
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700;900&family=Inter:wght@300;400;600;700;900&display=swap" rel="stylesheet">

<!-- ============================================================
     CSS — すべてのスタイルをここに記述
     ============================================================ -->
<style>
  /* ── リセット & 変数 ── */
  .mh-root {
    --mh-navy:       #0d2b5e;
    --mh-navy-mid:   #1a3a7a;
    --mh-blue:       #1e6abf;
    --mh-cyan:       #00a8d4;
    --mh-white:      #ffffff;
    --mh-off-white:  #f4f7fb;
    --mh-gray-light: #e8edf5;
    --mh-text-mid:   #3a4a5c;
    --mh-text-light: #6b7a8d;
  }

  /* ============================================================
     トップバー
     ============================================================ */
  .mh-topbar {
    background: #0d2b5e;
    height: 34px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 48px;
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 1001;
    box-sizing: border-box;
  }

  /* 左：キャッチコピー */
  .mh-topbar-catch {
    font-size: 11px;
    color: rgba(255,255,255,0.65);
    letter-spacing: 0.12em;
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'Noto Sans JP', sans-serif;
  }
  .mh-topbar-catch::before {
    content: '';
    display: block;
    width: 18px;
    height: 1px;
    background: #00a8d4;
    opacity: 0.8;
    flex-shrink: 0;
  }

  /* 右：メール受付バッジ */
  .mh-topbar-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: rgba(0,168,212,0.18);
    border: 1px solid rgba(0,168,212,0.4);
    color: #00a8d4;
    font-size: 10px;
    font-weight: 700;
    padding: 3px 12px;
    border-radius: 20px;
    letter-spacing: 0.06em;
    font-family: 'Noto Sans JP', sans-serif;
    white-space: nowrap;
  }
  .mh-topbar-badge i { font-size: 8px; }

  /* ============================================================
     ナビゲーションバー
     ============================================================ */
  .mh-nav {
    position: fixed;
    top: 34px;
    width: 100%;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 40px;
    height: 76px;
    background: #ffffff;
    border-bottom: 1px solid rgba(13,43,94,0.10);
    box-shadow: 0 2px 16px rgba(13,43,94,0.07);
    transition: box-shadow 0.3s;
    gap: 12px;
    box-sizing: border-box;
  }
  .mh-nav.mh-scrolled {
    box-shadow: 0 4px 24px rgba(13,43,94,0.13);
  }

  /* ── ロゴ ── */
  .mh-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    flex-shrink: 0;
  }
  .mh-logo-icon {
    width: 40px;
    height: 40px;
    background: linear-gradient(135deg, #0d2b5e 0%, #1e6abf 100%);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    font-weight: 900;
    color: #fff;
    font-family: 'Inter', sans-serif;
    flex-shrink: 0;
    box-shadow: 0 3px 12px rgba(13,43,94,0.25);
  }
  .mh-logo-text {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }
  .mh-logo-sub {
    font-size: 8px;
    color: #1e6abf;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 600;
    font-family: 'Inter', sans-serif;
    line-height: 1;
  }
  .mh-logo-name {
    font-size: 15px;
    font-weight: 800;
    color: #0d2b5e;
    letter-spacing: 0.05em;
    line-height: 1.1;
    font-family: 'Inter', sans-serif;
  }

  /* ── ナビリンク（PC中央） ── */
  .mh-nav-links {
    display: flex;
    align-items: center;
    gap: 0;
    list-style: none;
    flex: 1;
    justify-content: center;
    margin: 0;
    padding: 0;
  }
  .mh-nav-links a {
    display: block;
    padding: 6px 11px;
    color: #3a4a5c;
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.02em;
    border-radius: 6px;
    transition: all 0.2s;
    white-space: nowrap;
    position: relative;
    font-family: 'Noto Sans JP', sans-serif;
  }
  .mh-nav-links a::after {
    content: '';
    position: absolute;
    bottom: 2px;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 2px;
    background: #1e6abf;
    border-radius: 2px;
    transition: width 0.25s;
  }
  .mh-nav-links a:hover { color: #0d2b5e; }
  .mh-nav-links a:hover::after { width: 65%; }

  /* ── 右エリア（電話カード＋見積ボタン） ── */
  .mh-nav-contact {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }

  /* 電話カード */
  .mh-phone-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    background: linear-gradient(135deg, #f0f5ff 0%, #ffffff 100%);
    border: 1.5px solid rgba(13,43,94,0.14);
    border-radius: 12px;
    padding: 6px 16px 6px 8px;
    transition: all 0.25s;
    white-space: nowrap;
    box-shadow: 0 2px 12px rgba(13,43,94,0.08);
    position: relative;
    overflow: hidden;
  }
  /* 左端シアンライン */
  .mh-phone-btn::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    background: linear-gradient(to bottom, #00a8d4, #1e6abf);
    border-radius: 12px 0 0 12px;
  }
  .mh-phone-btn:hover {
    border-color: #1e6abf;
    background: linear-gradient(135deg, #e8f0ff 0%, #f8fbff 100%);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(13,43,94,0.14);
  }
  .mh-phone-icon {
    width: 32px;
    height: 32px;
    background: linear-gradient(135deg, #0d2b5e, #1e6abf);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 3px 10px rgba(13,43,94,0.22);
  }
  .mh-phone-icon i { font-size: 13px; color: #fff; }
  .mh-phone-text {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }
  .mh-phone-label {
    font-size: 9px;
    letter-spacing: 0.14em;
    color: #00a8d4;
    font-weight: 800;
    line-height: 1;
    font-family: 'Noto Sans JP', sans-serif;
  }
  .mh-phone-number {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 900;
    color: #0d2b5e;
    letter-spacing: 0.06em;
    line-height: 1.1;
  }
  .mh-phone-hours {
    font-size: 8.5px;
    color: #6b7a8d;
    letter-spacing: 0.02em;
    line-height: 1.25;
    font-family: 'Noto Sans JP', sans-serif;
    margin-top: 1px;
  }

  /* 見積依頼ボタン */
  .mh-estimate-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    background: linear-gradient(135deg, #0d2b5e 0%, #1e6abf 100%);
    color: #fff;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.04em;
    padding: 10px 22px;
    border-radius: 10px;
    white-space: nowrap;
    flex-shrink: 0;
    box-shadow: 0 4px 16px rgba(13,43,94,0.32);
    transition: all 0.25s;
    position: relative;
    overflow: hidden;
    font-family: 'Noto Sans JP', sans-serif;
  }
  /* シマーエフェクト */
  .mh-estimate-btn::before {
    content: '';
    position: absolute;
    top: 0; left: -100%;
    width: 60%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.18), transparent);
    transition: left 0.5s;
  }
  .mh-estimate-btn:hover::before { left: 150%; }
  .mh-estimate-btn:hover {
    background: linear-gradient(135deg, #1e6abf 0%, #1a3a7a 100%);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(13,43,94,0.38);
    color: #fff;
  }
  .mh-btn-arrow {
    width: 20px; height: 20px;
    background: rgba(255,255,255,0.18);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 10px;
    transition: transform 0.25s;
  }
  .mh-estimate-btn:hover .mh-btn-arrow { transform: translateX(3px); }

  /* ── ハンバーガーボタン（スマホのみ） ── */
  .mh-hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: #f4f7fb;
    border: 1px solid #e8edf5;
    border-radius: 8px;
    cursor: pointer;
    padding: 8px 10px;
    z-index: 1100;
  }
  .mh-hamburger span {
    display: block;
    width: 22px; height: 2px;
    background: #0d2b5e;
    border-radius: 2px;
    transition: all 0.3s;
  }
  .mh-hamburger.mh-active span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .mh-hamburger.mh-active span:nth-child(2) { opacity: 0; }
  .mh-hamburger.mh-active span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ============================================================
     モバイルオーバーレイ
     ============================================================ */
  .mh-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.35);
    z-index: 998;
    backdrop-filter: blur(2px);
  }
  .mh-overlay.mh-open { display: block; }

  /* ============================================================
     モバイルドロワー
     ============================================================ */
  .mh-drawer {
    display: none;
    position: fixed;
    top: 0; right: -100%;
    width: min(300px, 88vw);
    height: 100vh;
    height: 100dvh;
    background: #fff;
    z-index: 999;
    flex-direction: column;
    overflow: hidden;
    border-left: 1px solid #e8edf5;
    box-shadow: -8px 0 40px rgba(13,43,94,0.12);
    transition: right 0.35s cubic-bezier(0.4,0,0.2,1);
  }
  .mh-drawer.mh-open { right: 0; }

  /* ドロワーヘッダー（固定） */
  .mh-drawer-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    border-bottom: 2px solid #e8edf5;
    background: #fff;
    flex-shrink: 0;
  }
  .mh-drawer-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }
  .mh-drawer-logo-icon {
    width: 34px; height: 34px;
    background: linear-gradient(135deg, #0d2b5e, #1e6abf);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: 14px; font-weight: 900;
    font-family: 'Inter', sans-serif;
    flex-shrink: 0;
  }
  .mh-drawer-logo-text { display: flex; flex-direction: column; }
  .mh-drawer-logo-sub {
    font-size: 7px; color: #6b7a8d;
    letter-spacing: 0.08em; line-height: 1;
    font-family: 'Inter', sans-serif;
  }
  .mh-drawer-logo-name {
    font-size: 11px; font-weight: 900; color: #0d2b5e;
    letter-spacing: 0.04em; line-height: 1.3;
    font-family: 'Inter', sans-serif;
  }
  .mh-drawer-close {
    width: 36px; height: 36px;
    background: #f4f7fb;
    border: 1px solid #e8edf5;
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    font-size: 16px; color: #0d2b5e;
    flex-shrink: 0;
    transition: background 0.2s;
  }
  .mh-drawer-close:hover { background: #e8edf5; }

  /* ホームリンク（ヘッダー直下・スクロール外） */
  .mh-link-home {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 11px 20px;
    font-size: 13px; font-weight: 500;
    color: #3a4a5c;
    text-decoration: none;
    background: #f4f7fb;
    border-bottom: 2px solid #e8edf5;
    flex-shrink: 0;
    font-family: 'Noto Sans JP', sans-serif;
    transition: all 0.2s;
  }
  .mh-link-home:hover { background: #e8f0fc; color: #0d2b5e; }
  .mh-link-home i { color: #1e6abf; font-size: 11px; }

  /* スクロールエリア */
  .mh-drawer-scroll {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 24px;
  }

  /* ドロワーリンク */
  .mh-drawer-link {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 11px 20px;
    color: #3a4a5c;
    text-decoration: none;
    font-size: 13px; font-weight: 500;
    border-bottom: 1px solid #e8edf5;
    transition: all 0.2s;
    font-family: 'Noto Sans JP', sans-serif;
    position: relative;
  }
  .mh-drawer-link::before {
    content: '';
    display: block;
    width: 3px; height: 16px;
    background: transparent;
    border-radius: 2px;
    transition: background 0.2s;
    flex-shrink: 0;
  }
  .mh-drawer-link:hover {
    background: #f4f7fb;
    color: #0d2b5e;
    padding-left: 28px;
  }
  .mh-drawer-link:hover::before { background: #1e6abf; }
  .mh-drawer-link i { color: #1e6abf; font-size: 11px; }

  /* 見積依頼CTAボタン（ドロワー内） */
  .mh-drawer-estimate {
    margin: 14px 16px 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: linear-gradient(135deg, #0d2b5e, #1e6abf);
    color: #fff;
    text-decoration: none;
    padding: 12px 16px;
    border-radius: 10px;
    font-size: 13px; font-weight: 800;
    letter-spacing: 0.04em;
    box-shadow: 0 4px 16px rgba(13,43,94,0.28);
    transition: all 0.25s;
    font-family: 'Noto Sans JP', sans-serif;
  }
  .mh-drawer-estimate:hover {
    background: linear-gradient(135deg, #1e6abf, #1a3a7a);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(13,43,94,0.36);
    color: #fff;
  }

  /* 連絡先カード（ドロワー内） */
  .mh-drawer-contact {
    margin: 12px 16px 0;
    padding: 14px 16px;
    background: #f4f7fb;
    border-radius: 12px;
    border: 1px solid #e8edf5;
  }
  .mh-drawer-contact-label {
    font-size: 9px; font-weight: 800;
    letter-spacing: 0.16em; color: #00a8d4;
    text-transform: uppercase; margin-bottom: 4px;
    font-family: 'Noto Sans JP', sans-serif;
  }
  .mh-drawer-phone {
    display: flex; align-items: center; gap: 7px;
    text-decoration: none; color: #0d2b5e;
    font-family: 'Inter', sans-serif;
    font-size: 18px; font-weight: 900;
    letter-spacing: 0.04em; margin-bottom: 3px;
  }
  .mh-drawer-phone i { color: #1e6abf; font-size: 13px; }
  .mh-drawer-hours {
    font-size: 9.5px; color: #6b7a8d;
    line-height: 1.5; margin-bottom: 10px;
    font-family: 'Noto Sans JP', sans-serif;
  }
  .mh-drawer-email {
    display: flex; align-items: center; gap: 6px;
    text-decoration: none; color: #6b7a8d;
    font-size: 11px; padding: 4px 0;
    font-family: 'Noto Sans JP', sans-serif;
  }
  .mh-drawer-email i { color: #1e6abf; font-size: 10px; }

  /* ページオフセット（ヘッダー分の余白）*/
  .mh-page-offset { height: 110px; }

  /* ============================================================
     レスポンシブ
     ============================================================ */

  /* PC（1024px以上）：ナビ・電話・見積ボタン表示、ハンバーガー非表示 */
  @media (min-width: 1024px) {
    .mh-nav-links    { display: flex !important; }
    .mh-nav-contact  { display: flex !important; }
    .mh-hamburger    { display: none !important; }
    .mh-drawer       { display: none !important; }
  }

  /* 中画面PC（1024〜1380px）：各要素を少しコンパクトに */
  @media (min-width: 1024px) and (max-width: 1380px) {
    .mh-nav          { padding: 0 16px; gap: 8px; }
    .mh-nav-links a  { padding: 6px 8px; font-size: 12px; }
    .mh-nav-contact  { gap: 8px; }
    .mh-phone-btn    { padding: 6px 12px 6px 8px; gap: 8px; }
    .mh-phone-icon   { width: 30px; height: 30px; border-radius: 7px; }
    .mh-phone-icon i { font-size: 12px; }
    .mh-phone-number { font-size: 15px; }
    .mh-phone-hours  { font-size: 8px; }
    .mh-estimate-btn { font-size: 12px; padding: 9px 16px; }
    .mh-logo-name    { font-size: 14px; }
  }

  /* 大画面PC（1381px以上）：余白を広く */
  @media (min-width: 1381px) {
    .mh-nav    { padding: 0 48px; }
    .mh-topbar { padding: 0 48px; }
  }

  /* スマホ・タブレット（1023px以下）：ハンバーガー表示、ナビ非表示 */
  @media (max-width: 1023px) {
    .mh-nav          { padding: 0 24px; }
    .mh-nav-links    { display: none !important; }
    .mh-nav-contact  { display: none !important; }
    .mh-hamburger    { display: flex; }
    .mh-drawer       { display: flex; }
  }

  /* スマホ（767px以下）：トップバーのキャッチを非表示 */
  @media (max-width: 767px) {
    .mh-topbar       { padding: 0 20px; }
    .mh-nav          { padding: 0 20px; }
    .mh-topbar-catch { display: none; }
  }
</style>

<!-- ============================================================
     HTML — トップバー
     ============================================================ -->
<div class="mh-root">

  <div class="mh-topbar">
    <div class="mh-topbar-catch">{{ section.settings.topbar_catch }}</div>
    <div class="mh-topbar-badge">
      <i class="fa fa-envelope"></i>{{ section.settings.topbar_badge }}
    </div>
  </div>

  <!-- ============================================================
       HTML — ナビゲーションバー
       ============================================================ -->
  <nav class="mh-nav" id="mhNav">

    <!-- ロゴ -->
    <a href="{{ routes.root_url }}" class="mh-logo">
      <div class="mh-logo-icon">M</div>
      <div class="mh-logo-text">
        <span class="mh-logo-sub">{{ section.settings.logo_sub }}</span>
        <span class="mh-logo-name">{{ section.settings.logo_name }}</span>
      </div>
    </a>

    <!-- ナビリンク（PC） -->
    <ul class="mh-nav-links">
      <li><a href="{{ routes.root_url }}">ホーム</a></li>
      {% for link in linklists[section.settings.menu].links %}
        <li><a href="{{ link.url }}">{{ link.title }}</a></li>
      {% endfor %}
    </ul>

    <!-- 右エリア：電話カード＋見積ボタン -->
    <div class="mh-nav-contact">

      <!-- 電話カード -->
      <a href="tel:{{ section.settings.phone_number | remove: '-' }}" class="mh-phone-btn">
        <div class="mh-phone-icon"><i class="fa fa-phone"></i></div>
        <div class="mh-phone-text">
          <span class="mh-phone-label">フリーダイヤル</span>
          <span class="mh-phone-number">{{ section.settings.phone_number }}</span>
          <span class="mh-phone-hours">
            {{ section.settings.phone_hours_1 }}<br>
            {{ section.settings.phone_hours_2 }}
          </span>
        </div>
      </a>

      <!-- 見積依頼ボタン -->
      <a href="{{ section.settings.estimate_url }}" class="mh-estimate-btn">
        <i class="fa fa-file-alt"></i>
        {{ section.settings.estimate_label }}
        <span class="mh-btn-arrow"><i class="fa fa-arrow-right"></i></span>
      </a>

    </div>

    <!-- ハンバーガーボタン（スマホのみ） -->
    <button class="mh-hamburger" id="mhHamburger" aria-label="メニューを開く">
      <span></span><span></span><span></span>
    </button>

  </nav>

  <!-- ============================================================
       HTML — モバイルオーバーレイ & ドロワー
       ============================================================ -->
  <div class="mh-overlay" id="mhOverlay"></div>

  <div class="mh-drawer" id="mhDrawer">

    <!-- ドロワーヘッダー（固定） -->
    <div class="mh-drawer-header">
      <a href="{{ routes.root_url }}" class="mh-drawer-logo" id="mhDrawerLogoLink">
        <div class="mh-drawer-logo-icon">M</div>
        <div class="mh-drawer-logo-text">
          <span class="mh-drawer-logo-sub">{{ section.settings.logo_sub }}</span>
          <span class="mh-drawer-logo-name">{{ section.settings.logo_name }}</span>
        </div>
      </a>
      <button class="mh-drawer-close" id="mhDrawerClose" aria-label="メニューを閉じる">
        <i class="fa fa-times"></i>
      </button>
    </div>

    <!-- ホームリンク（ドロワーヘッダー直下・スクロール外） -->
    <a href="{{ routes.root_url }}" class="mh-link-home mh-drawer-close-trigger">
      <i class="fa fa-home"></i>ホーム
    </a>

    <!-- スクロール可能エリア -->
    <div class="mh-drawer-scroll">

      <!-- ナビリンク（メニューから自動生成） -->
      {% assign icons = "fa-lightbulb,fa-cogs,fa-shopping-cart,fa-chart-bar,fa-tag,fa-car,fa-building,fa-info-circle" | split: "," %}
      {% for link in linklists[section.settings.menu].links %}
        <a href="{{ link.url }}" class="mh-drawer-link mh-drawer-close-trigger">
          <i class="fa {{ icons[forloop.index0] }}"></i>{{ link.title }}
        </a>
      {% endfor %}

      <!-- 見積依頼CTAボタン -->
      <a href="{{ section.settings.estimate_url }}" class="mh-drawer-estimate mh-drawer-close-trigger">
        <i class="fa fa-file-alt"></i>
        {{ section.settings.estimate_label }}
        <i class="fa fa-arrow-right" style="font-size:10px;margin-left:4px;"></i>
      </a>

      <!-- 連絡先カード -->
      <div class="mh-drawer-contact">
        <div class="mh-drawer-contact-label">フリーダイヤル</div>
        <a href="tel:{{ section.settings.phone_number | remove: '-' }}" class="mh-drawer-phone">
          <i class="fa fa-phone"></i>{{ section.settings.phone_number }}
        </a>
        <div class="mh-drawer-hours">
          {{ section.settings.phone_hours_1 }}<br>
          {{ section.settings.phone_hours_2 }}
        </div>
        <a href="mailto:{{ section.settings.email }}" class="mh-drawer-email">
          <i class="fa fa-envelope"></i>{{ section.settings.email }}
        </a>
      </div>

    </div><!-- /mh-drawer-scroll -->
  </div><!-- /mh-drawer -->

  <!-- ページコンテンツのオフセット（ヘッダー分の余白） -->
  <div class="mh-page-offset"></div>

</div><!-- /mh-root -->

<!-- ============================================================
     JavaScript — ハンバーガー開閉 & スクロール検知
     ============================================================ -->
<script>
document.addEventListener('DOMContentLoaded', function() {

  // 要素を取得
  var nav        = document.getElementById('mhNav');
  var hamburger  = document.getElementById('mhHamburger');
  var drawer     = document.getElementById('mhDrawer');
  var overlay    = document.getElementById('mhOverlay');

  // ── スクロール検知：ナビに.mh-scrolledクラスを付与 ──
  window.addEventListener('scroll', function() {
    if (window.scrollY > 60) {
      nav.classList.add('mh-scrolled');
    } else {
      nav.classList.remove('mh-scrolled');
    }
  });

  // ── ドロワーを開く ──
  function openDrawer() {
    hamburger.classList.add('mh-active');
    drawer.classList.add('mh-open');
    overlay.classList.add('mh-open');
    document.body.style.overflow = 'hidden';
  }

  // ── ドロワーを閉じる ──
  function closeDrawer() {
    hamburger.classList.remove('mh-active');
    drawer.classList.remove('mh-open');
    overlay.classList.remove('mh-open');
    document.body.style.overflow = '';
  }

  // ── ハンバーガーボタンのクリック ──
  hamburger.addEventListener('click', function() {
    if (drawer.classList.contains('mh-open')) {
      closeDrawer();
    } else {
      openDrawer();
    }
  });

  // ── 閉じるボタンのクリック ──
  document.getElementById('mhDrawerClose').addEventListener('click', closeDrawer);

  // ── オーバーレイのクリック ──
  overlay.addEventListener('click', closeDrawer);

  // ── ドロワー内リンクのクリックで自動的に閉じる ──
  var closeTargets = drawer.querySelectorAll('.mh-drawer-close-trigger');
  closeTargets.forEach(function(el) {
    el.addEventListener('click', closeDrawer);
  });

  // ── ロゴクリックでも閉じる ──
  document.getElementById('mhDrawerLogoLink').addEventListener('click', closeDrawer);

});
</script>

